# LLM backend to use for Layer 3: "vllm" (default) or "ollama"
LLM_BACKEND=vllm

# vLLM settings (used when LLM_BACKEND=vllm)
# Any HuggingFace model ID — must fit in VRAM.
# Phi-3-mini (~2.2GB VRAM) is a fast, capable default.
# For better Dutch: CohereForAI/aya-expanse-8b (~16GB VRAM, needs HF_TOKEN)
VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# HuggingFace token — only needed for gated models (e.g. Llama, Aya)
HF_TOKEN=

# Ollama settings (used when LLM_BACKEND=ollama)
# Start with: docker compose --profile ollama up
# Recommended for Dutch/English: aya-expanse:8b
# Alternative for strict privacy: llama3.1:8b
OLLAMA_MODEL=aya-expanse:8b
